location    = "westeurope"
environment = "dev"

tags = {
  environment = "dev"
  project     = "azure-landing-zone-foundation"
  managed_by  = "terraform"
}

network_security_groups = {
  hub = {
    name = "nsg-hub-dev-westeurope"
  }

  app = {
    name = "nsg-app-dev-westeurope"
  }

  data = {
    name = "nsg-data-dev-westeurope"
  }
}

subnets = {
  hub_shared = {
    name             = "snet-hub-shared-dev-westeurope"
    virtual_network  = "hub"
    address_prefixes = ["10.0.1.0/24"]
  }

  app = {
    name             = "snet-app-dev-westeurope"
    virtual_network  = "spoke_workload"
    address_prefixes = ["10.1.1.0/24"]
  }

  data = {
    name             = "snet-data-dev-westeurope"
    virtual_network  = "spoke_workload"
    address_prefixes = ["10.1.2.0/24"]
  }

  shared_services = {
    name             = "snet-shared-services-dev-westeurope"
    virtual_network  = "spoke_shared"
    address_prefixes = ["10.2.1.0/24"]
  }
}

subscription_id = "00000000-0000-0000-0000-000000000000"

subnet_nsg_association = {
  hub_shared = {
    subnet_key = "hub_shared"
    nsg_key = "hub"
  }

app = {
  subnet_key = "app"
  nsg_key = "app"
}

 data = {
    subnet_key = "data"
    nsg_key    = "data"
  }

}

vnet_peerings = {
  hub_to_spoke_workload = {
    name                         = "peer-hub-to-spoke-workload"
    virtual_network              = "hub"
    remote_virtual_network       = "spoke_workload"
    allow_virtual_network_access = true
    allow_forwarded_traffic      = true
    allow_gateway_transit        = false
    use_remote_gateways          = false
  }

  spoke_workload_to_hub = {
    name                         = "peer-spoke-workload-to-hub"
    virtual_network              = "spoke_workload"
    remote_virtual_network       = "hub"
    allow_virtual_network_access = true
    allow_forwarded_traffic      = true
    allow_gateway_transit        = false
    use_remote_gateways          = false
  }
}

